# ===== 百度云 OCR（免费注册：https://cloud.baidu.com/product/ocr） =====
# 1. 登录百度云 → 控制台 → 文字识别
# 2. 创建应用，获取以下三个值
BAIDU_OCR_APP_ID=你的AppID
BAIDU_OCR_API_KEY=你的API Key
BAIDU_OCR_SECRET_KEY=你的Secret Key

# ===== DeepSeek API（注册送额度：https://platform.deepseek.com） =====
DEEPSEEK_API_KEY=你的DeepSeek API Key
# DeepSeek 的基础 URL，通常不需要修改
DEEPSEEK_BASE_URL=https://api.deepseek.com
